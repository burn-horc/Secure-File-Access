{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "allowJs": true
  },
  "include": [
    "api/**/*.ts",
    "server/**/*.ts",
    "server/**/*.d.ts",
    "client/**/*.ts",
    "client/**/*.tsx"
  ]
}
